{
  "name": "wsc-website",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host",
    "build": "tsx scripts/seo-audit/generate-public-seo-files.ts && vite build && tsx scripts/seo-audit/generate-static-route-html.ts && node scripts/seo-audit/defer-built-css.mjs && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "content:test": "node --test scripts/content-regression.test.mjs",
    "constant-contact:check": "node scripts/check-constant-contact-setup.mjs",
    "postmark:check": "node scripts/check-postmark-setup.mjs",
    "postmark:smoke-forms": "tsx scripts/smoke-test-form-delivery.mjs",
    "verify": "pnpm check && pnpm build",
    "seo:test-deployed": "node scripts/seo-audit/test-deployed-redirects.mjs",
    "seo:prelaunch-report": "node scripts/seo-audit/generate-prelaunch-report.mjs",
    "scrape:live": "node scripts/scrape-wsc-live.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
