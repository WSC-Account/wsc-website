    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.10",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.3",
    "vite": "^8.0.10"
